1. Tạo bảng trong layer (DWH - Staging )

  CREATE TABLE stg_content_mkt.fact_content_profile (
      id VARCHAR PRIMARY KEY,         -- Đây sẽ là ID gốc nối với Ngày (unique_id)
      business_id VARCHAR,
      account_nm VARCHAR(255),
      platform VARCHAR(50),           
      is_active BOOLEAN DEFAULT TRUE, 
      start_date DATE,                -- Lưu ngày chi tiết từ trong JSON
      end_date DATE,                  
      request_date TIMESTAMP,
      -- Các metrics bóc tách từ JSON
      likes INT DEFAULT 0,
      comments INT DEFAULT 0,
      shares INT DEFAULT 0,
      video_views INT DEFAULT 0,
      profile_views INT DEFAULT 0,
      bio_click_links INT DEFAULT 0,
      followers_count INT DEFAULT 0,
      engaged_audience INT DEFAULT 0,
      etl_updated_at TIMESTAMP DEFAULT NOW()
  );


2. Tạo hàm xử lý (Trigger Function) có gán platform -> tự động upsert data từ schema raw_tiktok

  CREATE OR REPLACE FUNCTION stg_content_mkt.fn_upsert_content_profile_tiktok()
  RETURNS TRIGGER AS $$
  BEGIN
      INSERT INTO stg_content_mkt.fact_content_profile (
          id, business_id, account_nm, platform, is_active,
          start_date, end_date, request_date, 
          likes, comments, shares, video_views, profile_views, 
          bio_click_links, followers_count, engaged_audience, 
          etl_updated_at
      )
      SELECT 
          NEW.id || '_' || (item->>'date'), -- Tạo Unique ID bằng cách nối ID gốc và Date
          NEW.business_id, 
          NEW.account_nm, 
          'tiktok', 
          TRUE,
          (item->>'date')::DATE,
          NEW.end_date, 
          NEW.request_date,
          COALESCE((item->>'likes')::INT, 0),
          COALESCE((item->>'comments')::INT, 0),
          COALESCE((item->>'shares')::INT, 0),
          COALESCE((item->>'video_views')::INT, 0),
          COALESCE((item->>'profile_views')::INT, 0),
          COALESCE((item->>'bio_link_clicks')::INT, 0),
          COALESCE((item->>'followers_count')::INT, 0),
          COALESCE((item->>'engaged_audience')::INT, 0),
          NOW()
      FROM jsonb_array_elements(NEW.raw_json->'metrics') AS item
      ON CONFLICT (id) DO UPDATE SET
          likes = EXCLUDED.likes,
          comments = EXCLUDED.comments,
          shares = EXCLUDED.shares,
          video_views = EXCLUDED.video_views,
          profile_views = EXCLUDED.profile_views,
          bio_click_links = EXCLUDED.bio_click_links,
          followers_count = EXCLUDED.followers_count,
          engaged_audience = EXCLUDED.engaged_audience,
          etl_updated_at = NOW();
  
      RETURN NEW;
  END;
  $$ LANGUAGE plpgsql;

3. Gắn trigger cho bảng raw_tiktok.content_profile

  CREATE TRIGGER trg_sync_tiktok_profile
  AFTER INSERT OR UPDATE ON raw_tiktok.content_profile
  FOR EACH ROW
  EXECUTE FUNCTION stg_content_mkt.fn_upsert_content_profile_tiktok();

